    });

    // nav dropdown - active - heighlight
    $("a.dd-link.w-dropdown-link.w--current").parent(".dd-list").siblings(".dd-toggle").addClass("active");

    // 	popup
    $(".open-popup").click(function(){
      $(".popup-main").fadeIn();
    });
    $(".popup-box .close-btn").click(function(){
      var video_src = $(this).next().find("iframe").attr("src");
      $(this).next().find("iframe").attr("src", "");
      $(this).closest(".popup-main").fadeOut();
      $(this).next().find("iframe").attr("src", video_src);
    });
  });

</script>

